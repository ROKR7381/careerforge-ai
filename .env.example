# ===========================================
# CareerForge AI - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# Database (PostgreSQL)
# Local: "postgresql://postgres:postgres@localhost:5432/careerforge"
# Railway: "postgresql://user:password@host:5432/dbname?pgbouncer=true"
# Supabase: "postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/careerforge"

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Supabase (Auth + Storage) - Optional
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Razorpay (Payment Gateway for India)
# Sign up at: https://dashboard.razorpay.com
# Get keys from: Dashboard → Settings → API Keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=""           # rzp_test_xxx (test) or rzp_live_xxx (live)
RAZORPAY_KEY_SECRET=""                    # Kept secret, never exposed to client
RAZORPAY_WEBHOOK_SECRET=""                # Set in Razorpay Dashboard → Settings → Webhooks

# Razorpay Plan IDs (create plans in Razorpay Dashboard → Subscriptions → Plans)
RAZORPAY_STUDENT_PLAN_ID=""               # ₹5/month student plan
RAZORPAY_BUDGET_PLAN_ID=""                # ₹10/month budget plan
RAZORPAY_ANNUAL_PLAN_ID=""                # ₹99/year annual plan

# Stripe (Optional - for international customers)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Python Backend (AI Agent + Exporters)
NEXT_PUBLIC_PYTHON_API_URL="http://127.0.0.1:8003"

# JWT Secret for auth tokens - Generate: openssl rand -base64 32
JWT_SECRET="change-this-to-a-random-secret-in-production"

# Encryption key for stored API keys - Generate: openssl rand -base64 24
ENCRYPTION_KEY="change-this-to-a-32-char-key-for-aes!!"

# AI Provider Keys (at least one required for AI features)
OPENAI_API_KEY=""
GROQ_API_KEY=""
TAVILY_API_KEY=""

# Interview Agent Settings
NEXT_PUBLIC_INTERVIEW_MAX_QUESTIONS="10"
NEXT_PUBLIC_INTERVIEW_DEFAULT_FIELD="Tech"
NEXT_PUBLIC_INTERVIEW_DEFAULT_LEVEL="fresher"

# ===========================================
# Smart Job Discovery (Phase 1)
# ===========================================
# Source: Adzuna Jobs API (https://developer.adzuna.com/)
# Sign up free tier: 250 calls/month — sufficient for MVP.
# ADZUNA_APP_ID     = your app ID from Adzuna dashboard
# ADZUNA_APP_KEY    = your app key from Adzuna dashboard (keep secret)
# ADZUNA_BASE_URL   = usually https://api.adzuna.com/v1/api (override only for tests)
ADZUNA_APP_ID=""
ADZUNA_APP_KEY=""
ADZUNA_BASE_URL="https://api.adzuna.com/v1/api"
